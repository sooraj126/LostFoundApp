<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F14">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <ImageView
            android:id="@+id/imgDetail"
            android:layout_marginTop="45dp"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:scaleType="centerCrop"
            android:background="#1AFFFFFF" />

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/txtDetailName"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="-0.02"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/txtDetailType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#6382DC"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:background="#1A6382DC" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#66FFFFFF"
                android:textSize="13sp"
                android:layout_marginBottom="24dp" />


            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#22FFFFFF"
                android:layout_marginBottom="24dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHONE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6382DC"
                android:letterSpacing="0.12"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtDetailPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_marginBottom="20dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPTION"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6382DC"
                android:letterSpacing="0.12"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtDetailDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="20dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPORTED DATE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6382DC"
                android:letterSpacing="0.12"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtDetailDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_marginBottom="20dp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCATION"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#6382DC"
                android:letterSpacing="0.12"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtDetailLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:layout_marginBottom="32dp" />


            <Button
                android:id="@+id/btnDelete"
                android:text="Remove Advert"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="#FF6B6B"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#1AFF6B6B"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="← Back"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#1AFFFFFF" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>